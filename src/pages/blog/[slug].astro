---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const blogItems = await getCollection('blog');

  return blogItems.map((item: any) => ({
    params: { slug: item.id.replace(/\.md$/, '') },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
import { Image } from 'astro:assets';
import noimg_Image from 'src/assets/noimg.png';
---

<BaseLayout title={`${item.data.title} | TeamKOTOCA`} description={item.data.summary} currentPath="/blog">
  <article class="article-hero">
    <div class="container article-hero-grid fade-in">
      <div>
        <a class="back-link" href="/blog">← Blog一覧へ戻る</a>
        <span class="eyebrow">Blog Article</span>
        <h1>{item.data.title}</h1>
        <time datetime={item.data.date.toISOString()}>{item.data.date.toLocaleDateString('ja-JP')}</time>
        <p class="hero-copy">{item.data.summary}</p>
      </div>
      <Image src={noimg_Image} alt="記事の画像" width={800} height={450}/>
    </div>
  </article>

  <section>
    <div class="container article-shell fade-in">
      <article class="article-section prose">
        <Content />
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.9fr);
    gap: clamp(1.5rem, 5vw, 3rem);
    align-items: center;
  }
  .back-link {
    display: inline-flex;
    margin-bottom: 1rem;
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 0.2rem;
  }
  .article-hero h1 {
    margin: 0.8rem 0 1rem;
    font-size: clamp(2.2rem, 5vw, 4rem);
    line-height: 1.1;
  }
  .article-hero time { color: var(--muted); }
  .hero-copy {
    max-width: 48rem;
    color: var(--muted);
    font-size: 1.05rem;
  }
  .article-hero img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 1px solid var(--line);
    box-shadow: var(--shadow-card);
    background: var(--card-bg);
  }
  .article-shell {
    max-width: 860px;
    display: grid;
    gap: 2rem;
  }
  .article-section {
    padding: 1.6rem;
    background: linear-gradient(180deg, rgba(255,255,255,0.28), rgba(255,255,255,0.06)), var(--card-bg);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-card);
  }
  .prose :global(h2) {
    margin: 0 0 1rem;
    font-size: 1.5rem;
  }
  .prose :global(p) {
    margin: 0 0 1rem;
    color: var(--muted);
    line-height: 1.8;
  }
  .prose :global(p:last-child) { margin-bottom: 0; }
  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.4rem;
    color: var(--muted);
  }
  .prose :global(li + li) {
    margin-top: 0.45rem;
  }
  .prose :global(a) {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.2rem;
  }
  .prose :global(blockquote) {
    margin: 0 0 1rem;
    padding-left: 1rem;
    border-left: 3px solid var(--line);
    color: var(--muted);
  }
  .prose :global(code) {
    padding: 0.1rem 0.35rem;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 0.35rem;
    font-size: 0.92em;
  }
  @media (max-width: 800px) {
    .article-hero-grid { grid-template-columns: 1fr; }
  }
</style>
