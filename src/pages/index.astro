---
import BaseLayout from '../layouts/BaseLayout.astro';
import { blogItems, communityPartners, newsItems, projects, teamMembers } from '../components/siteData';

const socialIcons = {
  github: {
    label: 'GitHub',
    viewBox: '0 0 24 24',
    path: 'M12 2C6.477 2 2 6.484 2 12.017c0 4.426 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.699-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.004.071 1.532 1.033 1.532 1.033.892 1.53 2.341 1.088 2.91.832.091-.647.349-1.088.635-1.338-2.221-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.269 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.295 2.748-1.026 2.748-1.026.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.338 4.695-4.566 4.943.359.31.678.92.678 1.855 0 1.339-.012 2.419-.012 2.749 0 .269.18.58.688.481A10.02 10.02 0 0 0 22 12.017C22 6.484 17.523 2 12 2Z',
  },
  x: {
    label: 'X',
    viewBox: '0 0 24 24',
    path: 'M18.901 2H21.99l-6.75 7.715L23.176 22h-6.214l-4.866-6.349L6.54 22H3.448l7.219-8.251L1.176 2h6.371l4.399 5.797L18.901 2Zm-1.084 18.133h1.712L6.617 3.773H4.78l13.037 16.36Z',
  },
  qiita: {
    label: 'Qiita',
    viewBox: '0 0 24 24',
    path: 'M4 4h7.4c4.633 0 8.6 2.742 8.6 7.923C20 16.63 16.165 20 11.49 20H4V4Zm4.056 3.517v8.966h3.032c2.716 0 4.757-1.676 4.757-4.56 0-2.78-1.935-4.406-4.757-4.406H8.056Z',
  },
} as const;
---

<BaseLayout
  title="TeamKOTOCA - 公式サイト"
  description="kotoca.net — プログラマー集団 TeamKOTOCA の公式サイト。Cloudflare Pages向けのAstro静的サイト。"
  currentPath="/"
>
  <section class="hero-section mesh-section">
    <div class="container hero-grid fade-in">
      <div class="hero-copy">
        <span class="eyebrow">TeamKOTOCA</span>
        <h1>楽しく、すごいものを。</h1>
        <p class="lead">
          TeamKOTOCAは、実用性と遊び心を両立するソフトウェアやツールを育てるプログラマー集団です。
          Web / Rust / C / インフラまで横断し、個人のアイデアを実運用へ近づけます。
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="https://discord.gg/n55hNZ5gbn" target="_blank" rel="noreferrer">公式Discord</a>
          <a class="btn" href="#projects">プロジェクトを見る</a>
        </div>

        <div class="hero-panels">
          <article class="panel owner-panel floating-card">
            <span class="meta-label">運営</span>
            <strong>Povo43 (いんめ)</strong>
            <p>アーキテクチャ設計から実装、運用まで横断して進める中核メンバーです。</p>
          </article>
          <div class="stats-grid">
            <article class="stat-card">
              <strong>10+</strong>
              <p>進行中・保守中のプロジェクト</p>
            </article>
            <article class="stat-card accent-card">
              <strong>募集中</strong>
              <p>コアメンバー / コラボメンバー</p>
            </article>
            <article class="stat-card">
              <strong>Static Ready</strong>
              <p>Cloudflare Pages で公開しやすい静的構成</p>
            </article>
          </div>
        </div>
      </div>

      <aside class="hero-aside">
        <article class="story-card spotlight-card floating-card large-spotlight">
          <img src="/dummy.webp" alt="チーム紹介用のイメージ" loading="lazy" />
          <span class="meta-label">Pick Up</span>
          <h2>つくる余白を、もっと広く。</h2>
          <p>
            情報設計にゆとりを持たせ、余白・導線・視線移動にリズムをつけることで、
            トップページ全体を自然に読み進められる構成へ整えました。
          </p>
          <div class="pulse-orb" aria-hidden="true"></div>
        </article>
      </aside>
    </div>
  </section>

  <section class="ticker-section">
    <div class="ticker-shell" aria-label="TeamKOTOCAのキーワード">
      <div class="ticker-track">
        <span>Build Fast</span>
        <span>Ship Small</span>
        <span>Review Together</span>
        <span>Web / Rust / C / Infra</span>
        <span>Join TeamKOTOCA</span>
        <span>Build Fast</span>
        <span>Ship Small</span>
        <span>Review Together</span>
        <span>Web / Rust / C / Infra</span>
        <span>Join TeamKOTOCA</span>
      </div>
    </div>
  </section>

  <section id="about">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">About</span>
          <h2>組織について</h2>
        </div>
        <p class="section-copy">学習用で終わらせず、継続運用できるものを早く作り、早く試し、早く改善します。</p>
      </div>
      <div class="editorial-grid">
        <article class="manifesto-panel panel">
          <span class="meta-label">Manifesto</span>
          <h3>個人の熱量を、チームの推進力へ変える。</h3>
          <p>
            思いつきで終わらせず、試作・相談・改善を繰り返しながら「実際に使えるもの」へ育てるのがTeamKOTOCAのスタイルです。
          </p>
        </article>
        <div class="info-stack">
          <article class="card info-card tilt-card">
            <h3>Mission</h3>
            <p>「楽しく、すごいものを。」を合言葉に、実運用可能なソフトウェアを継続的に開発します。</p>
          </article>
          <article class="card info-card tilt-card">
            <h3>Value</h3>
            <p>早く作る、早く試す、早く改善する。レビューと対話を通じて個人の成長とチーム成果を両立します。</p>
          </article>
          <article class="card info-card tilt-card">
            <h3>Culture</h3>
            <p>初心者歓迎・提案歓迎・失敗歓迎。まず作ってみる姿勢を尊重し、役割に縛られず協力します。</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section id="projects">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Projects</span>
          <h2>プロジェクト一覧</h2>
        </div>
        <p class="section-copy">公開中の取り組みや、これから磨いていく構想を、見た目にも変化をつけながら一覧化しました。</p>
      </div>
      <div class="projects-showcase">
        {projects.map((project, index) => (
          <article class={`project-band ${index % 2 === 1 ? 'reverse' : ''}`}>
            <div class="project-band-copy">
              <span class="meta-label">0{index + 1}</span>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <div class="project-links">
                {project.links.map((link) => (
                  <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
                ))}
              </div>
            </div>
            <div class="project-band-visual">
              <img src={project.image} alt={project.imageAlt} loading="lazy" />
              <div class="visual-grid" aria-hidden="true">
                <span></span><span></span><span></span><span></span>
              </div>
              <strong>{project.title}</strong>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="news">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">News</span>
          <h2>お知らせ</h2>
        </div>
        <a class="text-link" href="/news">一覧ページへ</a>
      </div>
      <div class="timeline-list">
        {newsItems.map((item) => (
          <article class="timeline-item news-card">
            <div class="timeline-date">
              <span></span>
              <time datetime={item.date}>{item.date}</time>
            </div>
            <div>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="blog">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Blog</span>
          <h2>ブログ</h2>
        </div>
        <a class="text-link" href="/blog">一覧ページへ</a>
      </div>
      <div class="story-grid blog-feature-grid">
        {blogItems.map((item, index) => (
          <article class={`blog-card blog-feature ${index === 0 ? 'is-featured' : ''}`}>
            <span class="meta-label">Article</span>
            <time datetime={item.date}>{item.date}</time>
            <h3><a href={`/blog/${item.slug}`}>{item.title}</a></h3>
            <p>{item.summary}</p>
            <a class="text-link" href={`/blog/${item.slug}`}>記事を読む</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="team">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Team</span>
          <h2>メンバー</h2>
        </div>
      </div>
      <div class="profile-grid team-grid">
        {teamMembers.map((member) => (
          <article class="profile-card team-card">
            <img src={member.image} alt={`${member.name} のプロフィール画像`} loading="lazy" />
            <div class="profile-content">
              <h3>{member.name}</h3>
              <p class="profile-role">{member.role}</p>
              <p>{member.description}</p>
              {member.socials?.length ? (
                <div class="social-links" aria-label={`${member.name} の外部リンク`}>
                  {member.socials.map((social) => {
                    const icon = socialIcons[social.platform as keyof typeof socialIcons];
                    return (
                      <a href={social.href} target="_blank" rel="noreferrer" aria-label={`${member.name} の${social.label}`} title={social.label}>
                        <svg viewBox={icon.viewBox} aria-hidden="true" focusable="false">
                          <path d={icon.path}></path>
                        </svg>
                        <span>{social.label}</span>
                      </a>
                    );
                  })}
                </div>
              ) : null}
            </div>
          </article>
        ))}
        <article class="join-card panel">
          <span class="meta-label">募集職種</span>
          <h3>Web / Rust / C / Infra / Design</h3>
          <p>「作ってみたい」「誰かと一緒に育てたい」という気持ちがあれば、学生・社会人を問わず歓迎します。</p>
          <a class="btn btn-primary" href="https://discord.gg/n55hNZ5gbn" target="_blank" rel="noreferrer">募集を見る</a>
        </article>
      </div>
    </div>
  </section>

  <section id="activities">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Activities</span>
          <h2>活動内容</h2>
        </div>
      </div>
      <div class="activity-rail">
        <article class="activity-step card">
          <span class="step-no">01</span>
          <h3>共同開発</h3>
          <p>それぞれが作りたいものを持ち寄り、各自のタイミングで助け合いながら進める柔軟な共同開発スタイルです。</p>
        </article>
        <article class="activity-step card">
          <span class="step-no">02</span>
          <h3>設計レビュー</h3>
          <p>短いサイクルで相談しながら、実装だけでなくアーキテクチャや運用導線も整えます。</p>
        </article>
        <article class="activity-step card">
          <span class="step-no">03</span>
          <h3>ナレッジ共有</h3>
          <p>試したこと、失敗したこと、役立った手順をチームで共有し、次の挑戦を速くします。</p>
        </article>
      </div>
    </div>
  </section>

  <section id="communities">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Communities</span>
          <h2>連携コミュニティ</h2>
        </div>
      </div>
      <div class="profile-grid single-column">
        {communityPartners.map((community) => (
          <article class="profile-card partner-card">
            <img src={community.image} alt={`${community.name} の紹介画像`} loading="lazy" />
            <div class="profile-content">
              <h3>{community.name}</h3>
              <p>{community.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="contact">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Contact</span>
          <h2>お問い合わせ</h2>
        </div>
      </div>
      <article class="contact-card">
        <form action="https://sites-backends.onrender.com/contacts" method="post" class="contact-form">
          <label>
            <span>お名前</span>
            <input type="text" name="name" required />
          </label>
          <label>
            <span>メールアドレス</span>
            <input type="email" name="email" required />
          </label>
          <label>
            <span>お問い合わせ内容</span>
            <textarea name="message" rows="6" required></textarea>
          </label>
          <button type="submit">送信</button>
        </form>
      </article>
    </div>
  </section>

  <section id="recruit" class="recruit-section">
    <div class="container fade-in">
      <article class="recruit-banner">
        <div>
          <span class="eyebrow">Recruit</span>
          <h2>ページの下部でも、仲間を募集しています。</h2>
          <p>
            一緒に何かを育てたい人、レビューし合える開発仲間がほしい人、
            実運用に近い開発を経験したい人を歓迎します。雑談からでも気軽にどうぞ。
          </p>
        </div>
        <div class="recruit-actions">
          <a class="btn btn-primary" href="https://discord.gg/n55hNZ5gbn" target="_blank" rel="noreferrer">Discordで参加する</a>
          <a class="btn" href="#contact">まずは問い合わせる</a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-section { padding-top: clamp(3rem, 10vw, 7rem); }
  .mesh-section {
    position: relative;
    overflow: clip;
  }
  .mesh-section::before,
  .mesh-section::after {
    content: '';
    position: absolute;
    border-radius: 999px;
    filter: blur(18px);
    opacity: 0.55;
    pointer-events: none;
  }
  .mesh-section::before {
    width: 18rem;
    height: 18rem;
    top: 1rem;
    right: 8%;
    background: radial-gradient(circle, rgba(0, 0, 0, 0.12), transparent 68%);
    animation: drift 10s ease-in-out infinite;
  }
  .mesh-section::after {
    width: 12rem;
    height: 12rem;
    left: 4%;
    bottom: 0;
    background: radial-gradient(circle, rgba(255,255,255,0.7), transparent 68%);
    animation: drift 13s ease-in-out infinite reverse;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(300px, 0.9fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .hero-copy h1 { margin: 0.8rem 0 0; font-size: clamp(2.8rem, 6vw, 5.4rem); line-height: 1.02; }
  .lead,
  .section-copy,
  .project-band-copy p,
  .info-card p,
  .story-card p,
  .news-card p,
  .blog-card p,
  .contact-card,
  .owner-panel p,
  .stat-card p,
  .profile-content p,
  .manifesto-panel p,
  .activity-step p,
  .recruit-banner p,
  .join-card p { color: var(--muted); }

  .lead { margin-top: 1.4rem; max-width: 44rem; font-size: 1.05rem; }
  .hero-actions,
  .recruit-actions { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-top: 2rem; }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0.85rem 1.2rem;
    border: 2px solid var(--fg);
    font-weight: 700;
    transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease, color 180ms ease;
  }

  .btn:hover,
  .btn:focus-visible { transform: translateY(-2px); box-shadow: var(--shadow-card); }
  .btn-primary { background: var(--fg); color: var(--bg); }

  .hero-panels { display: grid; gap: 1rem; margin-top: 2rem; }
  .owner-panel,
  .spotlight-card,
  .info-card,
  .stat-card,
  .news-card,
  .blog-card,
  .contact-card,
  .manifesto-panel,
  .activity-step,
  .join-card,
  .recruit-banner { padding: 1.4rem; }

  .floating-card { animation: floatCard 7s ease-in-out infinite; }
  .owner-panel strong,
  .stat-card strong { display: block; margin-top: 0.6rem; font-size: 1.2rem; }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .accent-card {
    background: linear-gradient(135deg, rgba(0,0,0,0.92), rgba(0,0,0,0.74));
    color: var(--bg);
  }
  .accent-card p { color: rgba(244, 238, 205, 0.82); }

  .hero-aside { position: sticky; top: 6rem; }
  .spotlight-card {
    position: relative;
    isolation: isolate;
  }
  .spotlight-card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    margin-bottom: 1rem;
    border: 1px solid var(--line);
  }
  .spotlight-card h2 { margin: 0.8rem 0 1rem; font-size: clamp(1.7rem, 3vw, 2.5rem); }
  .pulse-orb {
    position: absolute;
    width: 7rem;
    height: 7rem;
    right: -1rem;
    bottom: -1rem;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.55), rgba(0,0,0,0.12) 60%, transparent 72%);
    animation: pulseGlow 4s ease-in-out infinite;
    z-index: -1;
  }

  .ticker-section {
    padding: 0 0 1rem;
    overflow: hidden;
  }
  .ticker-shell {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: rgba(255,255,255,0.24);
  }
  .ticker-track {
    display: flex;
    gap: 2rem;
    white-space: nowrap;
    padding: 0.9rem 1rem;
    width: max-content;
    animation: marquee 26s linear infinite;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .ticker-track span::before {
    content: '✦';
    margin-right: 2rem;
    opacity: 0.55;
  }

  .editorial-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 1.2rem;
    align-items: stretch;
  }
  .manifesto-panel {
    display: grid;
    align-content: end;
    min-height: 100%;
    background: linear-gradient(160deg, rgba(0,0,0,0.92), rgba(0,0,0,0.74));
    color: var(--bg);
  }
  .manifesto-panel p,
  .manifesto-panel .meta-label { color: rgba(244, 238, 205, 0.8); }
  .manifesto-panel h3 { font-size: clamp(1.8rem, 4vw, 3rem); line-height: 1.1; margin: 0.9rem 0 1rem; }
  .info-stack { display: grid; gap: 1rem; }
  .tilt-card { transition: transform 220ms ease, box-shadow 220ms ease; }
  .tilt-card:hover { transform: rotate(-1deg) translateY(-4px); box-shadow: var(--shadow-soft); }

  .projects-showcase { display: grid; gap: 1.1rem; }
  .project-band {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(260px, 0.8fr);
    gap: 1rem;
    align-items: stretch;
  }
  .project-band.reverse .project-band-copy { order: 2; }
  .project-band.reverse .project-band-visual { order: 1; }
  .project-band-copy,
  .project-band-visual {
    background: linear-gradient(180deg, rgba(255,255,255,0.28), rgba(255,255,255,0.06)), var(--card-bg);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-card);
    padding: 1.4rem;
    min-height: 100%;
  }
  .project-band h3,
  .activity-step h3,
  .join-card h3,
  .manifesto-panel h3,
  .recruit-banner h2 { margin: 0.75rem 0; }
  .project-band-visual {
    position: relative;
    display: grid;
    place-items: end start;
    overflow: hidden;
    min-height: 220px;
    background: linear-gradient(135deg, rgba(0,0,0,0.88), rgba(0,0,0,0.65));
    color: var(--bg);
    isolation: isolate;
  }
  .project-band-visual img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.52;
  }
  .project-band-visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.1), rgba(0,0,0,0.68));
    z-index: 0;
  }
  .visual-grid {
    position: absolute;
    inset: 1rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    z-index: 1;
  }
  .visual-grid span {
    border: 1px solid rgba(244, 238, 205, 0.24);
    background: linear-gradient(135deg, rgba(255,255,255,0.18), rgba(255,255,255,0));
    animation: shimmer 6s linear infinite;
  }
  .visual-grid span:nth-child(2) { animation-delay: -1.5s; }
  .visual-grid span:nth-child(3) { animation-delay: -3s; }
  .visual-grid span:nth-child(4) { animation-delay: -4.5s; }
