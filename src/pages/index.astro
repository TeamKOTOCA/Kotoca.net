---
import BaseLayout from '../layouts/BaseLayout.astro';
import { blogItems, communityPartners, newsItems, projects, teamMembers } from '../components/siteData';
---

<BaseLayout
  title="TeamKOTOCA - 公式サイト"
  description="kotoca.net — プログラマー集団 TeamKOTOCA の公式サイト。Cloudflare Pages向けのAstro静的サイト。"
  currentPath="/"
>
  <section class="hero-section">
    <div class="container hero-grid fade-in">
      <div class="hero-copy">
        <span class="eyebrow">TeamKOTOCA</span>
        <h1>楽しく、すごいものを。</h1>
        <p class="lead">
          TeamKOTOCAは、実用性と遊び心を両立するソフトウェアやツールを育てるプログラマー集団です。
          Web / Rust / C / インフラまで横断し、個人のアイデアを実運用へ近づけます。
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="https://discord.gg/n55hNZ5gbn" target="_blank" rel="noreferrer">公式Discord</a>
          <a class="btn" href="#projects">プロジェクトを見る</a>
        </div>

        <div class="hero-panels">
          <article class="panel owner-panel">
            <span class="meta-label">Owner</span>
            <strong>Povo43 (いんめ)</strong>
            <p>アーキテクチャ設計から実装、運用まで横断して進めるコアメンバーです。</p>
          </article>
          <div class="stats-grid">
            <article class="stat-card">
              <strong>10+</strong>
              <p>進行中・保守中プロジェクト</p>
            </article>
            <article class="stat-card">
              <strong>募集中</strong>
              <p>コアメンバー / コラボメンバー</p>
            </article>
            <article class="stat-card">
              <strong>Cloud Ready</strong>
              <p>Cloudflare Pagesで配信しやすい静的構成</p>
            </article>
          </div>
        </div>
      </div>

      <aside class="hero-aside">
        <article class="story-card spotlight-card">
          <img src="/dummy.webp" alt="チーム紹介用のダミー画像" loading="lazy" />
          <span class="meta-label">Focus</span>
          <h2>つくる余白を、もっと広く。</h2>
          <p>
            情報設計にゆとりを持たせ、セクション間の余白・導線・視線移動を整えたことで、
            以前の雰囲気を残したまま読みやすさと現代的な軽快さを高めました。
          </p>
        </article>
      </aside>
    </div>
  </section>

  <section id="about">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">About</span>
          <h2>組織について</h2>
        </div>
        <p class="section-copy">学習用で終わらせず、継続運用できるものを早く作り、早く試し、早く改善します。</p>
      </div>
      <div class="info-grid">
        <article class="card info-card">
          <h3>Mission</h3>
          <p>「楽しく、すごいものを。」を合言葉に、実運用可能なソフトウェアを継続的に開発します。</p>
        </article>
        <article class="card info-card">
          <h3>Value</h3>
          <p>早く作る、早く試す、早く改善する。レビューと対話を通じて個人の成長とチーム成果を両立します。</p>
        </article>
        <article class="card info-card">
          <h3>Culture</h3>
          <p>初心者歓迎・提案歓迎・失敗歓迎。まず作ってみる姿勢を尊重し、役割に縛られず協力します。</p>
        </article>
      </div>
    </div>
  </section>

  <section id="projects">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Projects</span>
          <h2>プロジェクト一覧</h2>
        </div>
        <p class="section-copy">公開中の取り組みや、これから磨いていく構想を一覧化しています。</p>
      </div>
      <div class="projects-grid">
        {projects.map((project) => (
          <article class="project-card">
            <div>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
            </div>
            <div class="project-links">
              {project.links.map((link) => (
                <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="news">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">News</span>
          <h2>News セクション</h2>
        </div>
        <a class="text-link" href="/news">一覧ページへ</a>
      </div>
      <div class="story-grid">
        {newsItems.map((item) => (
          <article class="news-card">
            <time datetime={item.date}>{item.date}</time>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="blog">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Blog</span>
          <h2>Blog セクション</h2>
        </div>
        <a class="text-link" href="/blog">一覧ページへ</a>
      </div>
      <div class="story-grid">
        {blogItems.map((item) => (
          <article class="blog-card">
            <time datetime={item.date}>{item.date}</time>
            <h3><a href={`/blog/${item.slug}`}>{item.title}</a></h3>
            <p>{item.summary}</p>
            <a class="text-link" href={`/blog/${item.slug}`}>個別ページで読む</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="team">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Team</span>
          <h2>メンバー</h2>
        </div>
      </div>
      <div class="profile-grid">
        {teamMembers.map((member) => (
          <article class="profile-card">
            <img src={member.image} alt={`${member.name} の紹介用ダミー画像`} loading="lazy" />
            <div class="profile-content">
              <h3>{member.name}</h3>
              <p class="profile-role">{member.role}</p>
              <p>{member.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="activities">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Activities</span>
          <h2>活動内容</h2>
        </div>
      </div>
      <div class="info-grid">
        <article class="card info-card">
          <h3>共同開発</h3>
          <p>それぞれが作りたいものを持ち寄り、各々のタイミングで助け合いながら進める柔軟な共同開発スタイルです。</p>
        </article>
        <article class="card info-card">
          <h3>設計レビュー</h3>
          <p>短いサイクルで相談しながら、実装だけでなくアーキテクチャや運用導線も整えます。</p>
        </article>
        <article class="card info-card">
          <h3>ナレッジ共有</h3>
          <p>試したこと、失敗したこと、役立った手順をチームで共有し、次の挑戦を速くします。</p>
        </article>
      </div>
    </div>
  </section>

  <section id="communities">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Communities</span>
          <h2>連携コミュニティ</h2>
        </div>
      </div>
      <div class="profile-grid single-column">
        {communityPartners.map((community) => (
          <article class="profile-card partner-card">
            <img src={community.image} alt={`${community.name} の紹介用ダミー画像`} loading="lazy" />
            <div class="profile-content">
              <h3>{community.name}</h3>
              <p>{community.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="contact">
    <div class="container fade-in">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Contact</span>
          <h2>お問い合わせ</h2>
        </div>
      </div>
      <article class="contact-card">
        <form action="https://sites-backends.onrender.com/contacts" method="post" class="contact-form">
          <label>
            <span>お名前</span>
            <input type="text" name="name" required />
          </label>
          <label>
            <span>メールアドレス</span>
            <input type="email" name="email" required />
          </label>
          <label>
            <span>お問い合わせ内容</span>
            <textarea name="message" rows="6" required></textarea>
          </label>
          <button type="submit">送信</button>
        </form>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-section { padding-top: clamp(3rem, 10vw, 7rem); }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(300px, 0.9fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .hero-copy h1 { margin: 0.8rem 0 0; font-size: clamp(2.8rem, 6vw, 5.4rem); line-height: 1.02; }
  .lead,
  .section-copy,
  .project-card p,
  .info-card p,
  .story-card p,
  .news-card p,
  .blog-card p,
  .contact-card,
  .owner-panel p,
  .stat-card p,
  .profile-content p { color: var(--muted); }

  .lead { margin-top: 1.4rem; max-width: 44rem; font-size: 1.05rem; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-top: 2rem; }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0.85rem 1.2rem;
    border: 2px solid var(--fg);
    font-weight: 700;
    transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease, color 180ms ease;
  }

  .btn:hover,
  .btn:focus-visible { transform: translateY(-2px); box-shadow: var(--shadow-card); }
  .btn-primary { background: var(--fg); color: var(--bg); }

  .hero-panels { display: grid; gap: 1rem; margin-top: 2rem; }
  .owner-panel,
  .spotlight-card,
  .info-card,
  .project-card,
  .stat-card,
  .news-card,
  .blog-card,
  .contact-card { padding: 1.4rem; }

  .owner-panel strong,
  .stat-card strong { display: block; margin-top: 0.6rem; font-size: 1.2rem; }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .hero-aside { position: sticky; top: 6rem; }
  .spotlight-card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    margin-bottom: 1rem;
    border: 1px solid var(--line);
  }
  .spotlight-card h2 { margin: 0.8rem 0 1rem; font-size: clamp(1.7rem, 3vw, 2.5rem); }

  .info-grid,
  .story-grid,
  .projects-grid,
  .profile-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .single-column { grid-template-columns: 1fr; }

  .project-card {
    display: grid;
    gap: 1.2rem;
    align-content: space-between;
    min-height: 100%;
  }

  .project-card h3,
  .news-card h3,
  .blog-card h3,
  .info-card h3,
  .profile-content h3 { margin: 0 0 0.7rem; font-size: 1.15rem; }
  .project-links { display: flex; flex-wrap: wrap; gap: 0.55rem; }

  .project-links a,
  .text-link,
  .news-card time,
  .blog-card time {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.92rem;
  }

  .project-links a {
    padding: 0.65rem 0.85rem;
    background: var(--fg);
    color: var(--bg);
    font-weight: 700;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .project-links a:hover,
  .text-link:hover { transform: translateY(-1px); opacity: 0.82; }

  .text-link { color: var(--muted); }
  .news-card time,
  .blog-card time { color: var(--muted); margin-bottom: 0.8rem; }

  .profile-card {
    display: grid;
    grid-template-columns: minmax(180px, 0.8fr) minmax(0, 1fr);
    background: linear-gradient(180deg, rgba(255,255,255,0.28), rgba(255,255,255,0.06)), var(--card-bg);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }
  .profile-card img {
    width: 100%;
    height: 100%;
    min-height: 220px;
    object-fit: cover;
    background: rgba(255,255,255,0.3);
  }
  .profile-content { padding: 1.4rem; }
  .profile-role {
    margin-top: -0.1rem;
    font-weight: 700;
    color: var(--fg) !important;
  }
  .partner-card { max-width: 860px; }

  .contact-card { max-width: 760px; }
  .contact-form { display: grid; gap: 1rem; }
  .contact-form label { display: grid; gap: 0.45rem; font-weight: 700; }
  .contact-form input,
  .contact-form textarea {
    width: 100%;
    border: 2px solid var(--fg);
    background: rgba(250, 247, 232, 0.9);
    padding: 0.9rem;
    font: inherit;
  }

  .contact-form button {
    justify-self: start;
    border: 2px solid var(--fg);
    background: var(--fg);
    color: var(--bg);
    padding: 0.85rem 1.8rem;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .contact-form button:hover { transform: translateY(-1px); opacity: 0.82; }

  @media (max-width: 1024px) {
    .hero-grid,
    .info-grid,
    .story-grid,
    .projects-grid,
    .profile-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .hero-aside { position: static; }
    .profile-card { grid-template-columns: 1fr; }
  }

  @media (max-width: 720px) {
    .hero-grid,
    .info-grid,
    .story-grid,
    .projects-grid,
    .stats-grid,
    .profile-grid { grid-template-columns: 1fr; }
    .hero-copy h1 { font-size: clamp(2.5rem, 14vw, 4rem); }
  }
</style>
