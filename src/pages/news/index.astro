---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { newsItems } from '../../components/siteData';
---

<BaseLayout title="News | TeamKOTOCA" description="TeamKOTOCAのNews一覧ページです。" currentPath="/news">
  <article class="page-hero">
    <div class="container fade-in">
      <span class="eyebrow">News</span>
      <h1>News</h1>
      <p>TeamKOTOCAの更新情報やお知らせを一覧で確認できます。</p>
    </div>
  </article>

  <section>
    <div class="container feed-list fade-in">
      {newsItems.map((item) => (
        <article class="feed-card">
          <time datetime={item.date}>{item.date}</time>
          <h2>{item.title}</h2>
          <p>{item.summary}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero p { max-width: 42rem; color: var(--muted); font-size: 1.05rem; }
  .feed-list { display: grid; gap: 1rem; }
  .feed-card {
    padding: 1.5rem;
    background: linear-gradient(180deg, rgba(255,255,255,0.28), rgba(255,255,255,0.06)), var(--card-bg);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-card);
  }
  .feed-card time { color: var(--muted); font-size: 0.92rem; }
  .feed-card h2 { margin: 0.55rem 0 0.8rem; font-size: 1.45rem; }
  .feed-card p { margin: 0; color: var(--muted); }
</style>
