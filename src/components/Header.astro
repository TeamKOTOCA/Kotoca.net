---
import { navItems } from './siteData';
const { currentPath = '/' } = Astro.props;
import { Image } from 'astro:assets';
import orgImage from 'src/assets/KOTOCA.webp';
---

<header class="site-header">
  <div class="container header-shell">
    <a class="brand" href="/" aria-label="TeamKOTOCA ホーム">
      <Image class="logo" src={ orgImage } alt="header画像"/>
      <div>
        <div class="brand-main">TeamKOTOCA</div>
        <div class="brand-sub">楽しく、すごいものを。</div>
      </div>
    </a>

    <details class="nav-wrap">
      <summary class="menu-toggle" aria-label="メニューを開閉">
        <span></span>
        <span></span>
        <span></span>
      </summary>

      <nav class="site-nav" aria-label="グローバルナビゲーション">
        <ul class="nav-list">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class={currentPath === item.href ? 'is-active' : undefined}>{item.label}</a>
            </li>
          ))}
          <li><a class="nav-cta" href="https://discord.gg/n55hNZ5gbn" target="_blank" rel="noreferrer">参加する</a></li>
        </ul>
      </nav>
    </details>
  </div>
</header>
